# Sentinel environment — copy to .env and fill in. (Real qualification stack.)

# --- Gemini 3 via Vertex AI (Application Default Credentials) ---
# Verified live: gemini-3.1-pro-preview serves on the GLOBAL endpoint.
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
SENTINEL_MODEL=gemini-3.1-pro-preview

# --- GitLab MCP (real partner integration) ---
# PAT with `api` scope. Default uses GitLab's official HTTP MCP server
# (https://gitlab.com/api/v4/mcp). Set SENTINEL_GITLAB_MCP=stdio to use the
# community stdio server (npx -y @zereight/mcp-gitlab) instead.
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_PROJECT_ID=
# SENTINEL_GITLAB_MCP=http

# --- Runtime ---
# Real stack (not the mock MCP / heuristic diagnoser):
SENTINEL_DEMO=false
# Auto-approve the gate only for non-interactive recordings/CI (fail-safe deny
# when unset). Keep UNSET so the human gate is exercised in the demo.
# SENTINEL_AUTO_APPROVE=true
