# Sentinel environment — copy to .env and fill in.

# Gemini 2.0 Flash (Google AI Studio API key). Optional in demo mode.
GEMINI_API_KEY=

# GitLab MCP (real mode only). Optional in demo mode.
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com

# Demo mode: use mock MCP + heuristic diagnosis, no API keys required.
SENTINEL_DEMO=true

# Non-interactive demo recordings/CI: auto-approve the gate when stdin is
# not a TTY. Leave unset for fail-safe (deny) behavior.
# SENTINEL_AUTO_APPROVE=true
